# OpenSpec CLI — environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env in your project root and fill in the values.
# Make sure .env is in your .gitignore — NEVER commit secrets.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
# ─────────────────────────────────────────────────────────────

# ── Jira Cloud ────────────────────────────────────────────────
# Your Jira instance URL (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# The email address associated with your Jira account
JIRA_EMAIL=your@email.com

# Jira API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_api_token

# Default Jira project key for os-tickets / os-create-ticket.
# If you work across multiple projects, override it per command instead of
# editing this file: os-tickets --project OTHER / os-create-ticket --project OTHER ...
JIRA_PROJECT_KEY=KAN
# Campo custom de Story Points en Jira Software (ajustar si tu instancia usa otro id).
# JIRA_STORY_POINTS_FIELD=customfield_10016

# ── Aplicación ────────────────────────────────────────────────
# Nivel de log del backend: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Un valor inválido degrada a INFO sin impedir el arranque.
# LOG_LEVEL=INFO

# Orígenes permitidos por CORS (JSON array — comillas dobles internas obligatorias).
# El frontend Angular corre en http://localhost:4200. Un valor mal formado hace
# fallar el arranque con ValidationError (fail-fast de configuración).
# ORIGENES_CORS='["http://localhost:4200"]'

# ── Base de datos ─────────────────────────────────────────────
# URL async de PostgreSQL (driver asyncpg). Obligatoria — sin default en producción.
# Coincide con las credenciales del docker-compose.yml (solo desarrollo local).
URL_BASE_DATOS=postgresql+asyncpg://usuario:contrasena@localhost:5432/sst_auditor

# Pool de conexión (opcional — defaults conservadores para una instancia; ajustar por entorno).
# Tamaño base del pool de conexiones (entero > 0).
# BD_POOL_TAMANO=5
# Conexiones extra permitidas por encima del pool (entero >= 0).
# BD_POOL_MAX_EXTRA=10
# Verifica la conexión antes de usarla (descarta conexiones muertas): true | false.
# BD_POOL_PRE_PING=true
# Segundos antes de reciclar una conexión (evita cierres por firewalls/proxies; entero > 0).
# BD_POOL_RECICLAR_SEGUNDOS=1800
# Loguea el SQL emitido (solo depuración): true | false.
# BD_ECHO_SQL=false

# ── Autenticación JWT ─────────────────────────────────────────
# Secreto de firma HS256. Obligatorio, mínimo 32 caracteres.
# Generar uno propio, p. ej.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRETO=cambia-este-secreto-de-al-menos-32-caracteres
# JWT_ALGORITMO=HS256
# JWT_MINUTOS_EXPIRACION_ACCESO=30
# JWT_DIAS_EXPIRACION_REFRESCO=7

# ── Seed del administrador inicial ────────────────────────────
# Solo las usa scripts/crear_usuario_admin.py — nunca hardcodear credenciales.
ADMIN_INICIAL_CORREO=admin@example.com
ADMIN_INICIAL_CONTRASENA=cambia-esta-contrasena
ADMIN_INICIAL_NOMBRE=Administrador Inicial

# ── GitHub (optional) ─────────────────────────────────────────
# The GitHub CLI (gh) handles auth separately.
# Run: gh auth login
# Only set this if you need a personal access token for scripting.
# GITHUB_TOKEN=your_github_personal_access_token
