#!/bin/sh
# os-plan <TICKET-ID>
# ─────────────────────────────────────────────────────────────
# Fetches a Jira ticket, resolves the active stack and agent,
# and delivers the implementation plan prompt accordingly.
# ─────────────────────────────────────────────────────────────
set -e

TICKET_ID="${1:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"
. "$CLI_DIR/lib/jira.sh"
. "$CLI_DIR/lib/agent.sh"
. "$CLI_DIR/lib/language.sh"

if [ -z "$TICKET_ID" ]; then
  os_error "Usage: os-plan <TICKET-ID>  (e.g. os-plan KAN-42)"
  exit 1
fi

# ── Load config and agent ────────────────────────────────────
os_load_config
os_load_env
os_load_agent
os_load_language

os_print_config
os_print_agent
os_print_language

# ── Fetch Jira ticket ────────────────────────────────────────
os_require_jira_env
os_jira_fetch_ticket "$TICKET_ID"
os_jira_print_ticket
os_jira_fetch_subtasks "$TICKET_ID"
os_jira_print_subtasks

# ── Load stack context ───────────────────────────────────────
os_step "Loading stack agent and standards..."

AGENT_CONTENT=""
if [ -f "$OS_AGENT_PATH" ]; then
  AGENT_CONTENT=$(cat "$OS_AGENT_PATH")
else
  os_warn "Stack agent not found at $OS_AGENT_PATH — skipping"
fi

STANDARDS_CONTENT=""
if [ -f "$OS_STANDARDS_PATH" ]; then
  STANDARDS_CONTENT=$(cat "$OS_STANDARDS_PATH")
else
  os_warn "Stack standards not found at $OS_STANDARDS_PATH — skipping"
fi

BASE_STANDARDS=""
BASE_FILE="$OS_REPO_ROOT/ai-specs/specs/base-standards.mdc"
[ -f "$BASE_FILE" ] && BASE_STANDARDS=$(cat "$BASE_FILE")

COMMAND_TEMPLATE=""
CMD_FILE="$OS_REPO_ROOT/ai-specs/.commands/plan-backend-ticket.md"
if [ -f "$CMD_FILE" ]; then
  COMMAND_TEMPLATE=$(cat "$CMD_FILE" \
    | sed "s|{{build_command}}|$OS_BUILD_CMD|g" \
    | sed "s|{{test_command}}|$OS_TEST_CMD|g" \
    | sed "s|{{run_command}}|$OS_RUN_CMD|g" \
    | sed "s|{{lint_command}}|$OS_LINT_CMD|g" \
    | sed "s|{{coverage_command}}|$OS_COVERAGE_CMD|g" \
    | sed "s|\$ARGUMENTS|$TICKET_ID|g")
fi

# ── Build prompt ─────────────────────────────────────────────
os_step "Building prompt..."

PROMPT="You are acting as the backend-developer agent for an openspec project.

## Active Language
$OS_LANGUAGE_LABEL
$OS_LANGUAGE_DIRECTIVE

## Active Stack
Stack    : $OS_ACTIVE_STACK ($OS_STACK_LABEL)
Build    : $OS_BUILD_CMD
Test     : $OS_TEST_CMD
Run      : $OS_RUN_CMD
Coverage : $OS_COVERAGE_CMD

## Jira Ticket: $JIRA_TICKET_ID
Type     : $JIRA_TYPE
Status   : $JIRA_STATUS
Summary  : $JIRA_SUMMARY
Assignee : $JIRA_ASSIGNEE

### Description
$JIRA_DESCRIPTION

---

## Subtasks
$JIRA_SUBTASKS_CONTEXT

---

## Base Standards
$BASE_STANDARDS

---

## Stack Agent (your role)
$AGENT_CONTENT

---

## Stack Standards
$STANDARDS_CONTENT

---

## Your Task
$COMMAND_TEMPLATE"

# ── Save and deliver prompt ──────────────────────────────────
PROMPT_FILE="$OS_REPO_ROOT/.openspec-cli/.last-prompt.md"
printf '%s' "$PROMPT" > "$PROMPT_FILE"

NEXT_STEPS="1. Open $OS_AGENT_LABEL
2. Paste the prompt
3. The AI will generate the plan at:
   ai-specs/changes/planes/${TICKET_ID}/${TICKET_ID}_backend.md
4. Review the plan, then run:
   os-develop $TICKET_ID"

os_deliver_prompt "$PROMPT_FILE" "$NEXT_STEPS"
