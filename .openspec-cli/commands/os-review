#!/bin/sh
# os-review <PR-NUMBER>
set -e

PR_NUMBER="${1:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"
. "$CLI_DIR/lib/agent.sh"

if [ -z "$PR_NUMBER" ]; then
  os_error "Usage: os-review <PR-NUMBER>"
  exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
  os_error "GitHub CLI (gh) not found — install from: https://cli.github.com"
  exit 1
fi

os_load_config
os_load_env
os_load_agent
os_print_config

# ── Fetch PR metadata ────────────────────────────────────────
os_step "Fetching PR #$PR_NUMBER metadata..."
PR_JSON=$(gh pr view "$PR_NUMBER" \
  --json title,body,headRefName,baseRefName,author,additions,deletions,changedFiles)

PR_TITLE=$(echo "$PR_JSON"   | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['title'])")
PR_BRANCH=$(echo "$PR_JSON"  | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['headRefName'])")
PR_BASE=$(echo "$PR_JSON"    | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['baseRefName'])")
PR_AUTHOR=$(echo "$PR_JSON"  | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['author']['login'])")
PR_ADD=$(echo "$PR_JSON"     | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['additions'])")
PR_DEL=$(echo "$PR_JSON"     | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['deletions'])")
PR_FILES=$(echo "$PR_JSON"   | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d['changedFiles'])")
PR_BODY=$(echo "$PR_JSON"    | py -X utf8 -c "import sys,json; d=json.load(sys.stdin); print(d.get('body','No description.'))")

os_divider
os_label "  PR #$PR_NUMBER: $PR_TITLE"
os_divider
os_info "Author  : $PR_AUTHOR"
os_info "Branch  : $PR_BRANCH -> $PR_BASE"
os_info "Changes : +$PR_ADD / -$PR_DEL across $PR_FILES files"
os_divider

# ── Download diff ────────────────────────────────────────────
os_step "Downloading PR diff..."
DIFF_FILE="$OS_REPO_ROOT/.openspec-cli/.pr-diff.patch"
gh pr diff "$PR_NUMBER" > "$DIFF_FILE" 2>/dev/null

DIFF_SIZE=$(wc -c < "$DIFF_FILE")
os_success "Diff: $(wc -l < "$DIFF_FILE") lines ($DIFF_SIZE bytes)"

MAX_BYTES=500000
if [ "$DIFF_SIZE" -gt "$MAX_BYTES" ]; then
  os_warn "Diff is large — truncating to 500KB"
  DIFF_CONTENT=$(head -c $MAX_BYTES "$DIFF_FILE")
  DIFF_CONTENT="$DIFF_CONTENT
... [truncated]"
else
  DIFF_CONTENT=$(cat "$DIFF_FILE")
fi

# ── Load context ─────────────────────────────────────────────
AGENT_CONTENT="";    [ -f "$OS_AGENT_PATH" ]     && AGENT_CONTENT=$(cat "$OS_AGENT_PATH")
STANDARDS_CONTENT="";[ -f "$OS_STANDARDS_PATH" ] && STANDARDS_CONTENT=$(cat "$OS_STANDARDS_PATH")
BASE_STANDARDS="";   BASE_FILE="$OS_REPO_ROOT/ai-specs/specs/base-standards.mdc"
                     [ -f "$BASE_FILE" ] && BASE_STANDARDS=$(cat "$BASE_FILE")

PLAN_CONTENT=""
TICKET_ID=$(echo "$PR_BRANCH" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)
if [ -n "$TICKET_ID" ]; then
  PLAN_FILE="$OS_REPO_ROOT/ai-specs/changes/${TICKET_ID}_backend.md"
  [ -f "$PLAN_FILE" ] && PLAN_CONTENT=$(cat "$PLAN_FILE")
fi

# ── Load review task template ─────────────────────────────────
REVIEW_TEMPLATE=""
REVIEW_CMD_FILE="$OS_REPO_ROOT/ai-specs/.commands/review-pr.md"
if [ -f "$REVIEW_CMD_FILE" ]; then
  REVIEW_TEMPLATE=$(cat "$REVIEW_CMD_FILE" \
    | sed "s|\$ARGUMENTS|$PR_NUMBER|g" \
    | sed "s|{{test_command}}|$OS_TEST_CMD|g" \
    | sed "s|{{coverage_command}}|$OS_COVERAGE_CMD|g")
fi

# ── Build prompt ─────────────────────────────────────────────
os_step "Building review prompt..."

PROMPT="You are an expert code reviewer for an openspec project.
Review the following Pull Request against the active stack standards.

## PR #$PR_NUMBER — $PR_TITLE
Author  : $PR_AUTHOR
Branch  : $PR_BRANCH -> $PR_BASE
Changes : +$PR_ADD / -$PR_DEL across $PR_FILES files

## PR Description
$PR_BODY

## Active Stack
Stack    : $OS_ACTIVE_STACK ($OS_STACK_LABEL)
Test     : $OS_TEST_CMD
Coverage : $OS_COVERAGE_CMD

---
## Base Standards
$BASE_STANDARDS

---
## Stack Agent
$AGENT_CONTENT

---
## Stack Standards
$STANDARDS_CONTENT"

if [ -n "$PLAN_CONTENT" ]; then
  PROMPT="$PROMPT

---
## Implementation Plan ($TICKET_ID)
$PLAN_CONTENT"
fi

PROMPT="$PROMPT

---
## PR Diff
\`\`\`diff
$DIFF_CONTENT
\`\`\`

---
## Your Task
$REVIEW_TEMPLATE"

PROMPT_FILE="$OS_REPO_ROOT/.openspec-cli/.last-prompt.md"
OUTPUT_FILE="$OS_REPO_ROOT/.openspec-cli/.review-output.md"
printf '%s' "$PROMPT" > "$PROMPT_FILE"

CHANGES_DIR="$OS_REPO_ROOT/ai-specs/changes"
mkdir -p "$CHANGES_DIR"
if [ -n "$TICKET_ID" ]; then
  REVIEW_ARCHIVE="$CHANGES_DIR/${TICKET_ID}_review.md"
else
  REVIEW_ARCHIVE="$CHANGES_DIR/pr-${PR_NUMBER}_review.md"
fi

os_divider

# ── Deliver and capture output ────────────────────────────────
if [ "${OS_AGENT_DELIVERY:-clipboard}" = "cli" ]; then
  os_step "Sending review prompt to $OS_AGENT_LABEL..."
  ${OS_AGENT_COMMAND} ${OS_AGENT_ARGS} < "$PROMPT_FILE" > "$OUTPUT_FILE" 2>/dev/null
  cp "$OUTPUT_FILE" "$REVIEW_ARCHIVE"
  os_success "Review saved!"
  os_info "Working : .openspec-cli/.review-output.md"
  os_info "Archive : $REVIEW_ARCHIVE"
  os_divider
  os_info "Preview (first 15 lines):"
  head -15 "$OUTPUT_FILE"
  os_divider
  os_info "Next step: os-review-apply $PR_NUMBER"
else
  printf '%s' "$PROMPT" | clip 2>/dev/null || true
  os_success "Prompt copied to clipboard!"
  os_info "1. Paste in $OS_AGENT_LABEL"
  os_info "2. Copy the review output"
  os_info "3. Press Enter here when ready..."
  read -r _dummy
  os_step "Paste the review (CTRL+Z + Enter to finish on Windows):"
  OUTPUT=""
  while IFS= read -r line 2>/dev/null; do
    OUTPUT="${OUTPUT}${line}
"
  done
  printf '%s' "$OUTPUT" > "$OUTPUT_FILE"
  cp "$OUTPUT_FILE" "$REVIEW_ARCHIVE"
  os_success "Review saved!"
  os_info "Working : .openspec-cli/.review-output.md"
  os_info "Archive : $REVIEW_ARCHIVE"
  os_divider
  os_info "Preview (first 15 lines):"
  head -15 "$OUTPUT_FILE"
  os_divider
  os_info "Next step: os-review-apply $PR_NUMBER"
fi

os_divider
