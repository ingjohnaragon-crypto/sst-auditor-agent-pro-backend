#!/usr/bin/bash
# os-tickets [status] [--project KEY]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS_CLI_LIB="${SCRIPT_DIR}/../lib"

source "${OS_CLI_LIB}/colors.sh"
source "${OS_CLI_LIB}/config.sh"

# Asegurar que OS_REPO_ROOT apunta al directorio actual del repo
export OS_REPO_ROOT="$(pwd)"
os_load_env
source "${OS_CLI_LIB}/jira.sh"

STATUS_FILTER=""
PROJECT_KEY_OVERRIDE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project|-p)
      shift
      PROJECT_KEY_OVERRIDE="${1:-}"
      ;;
    *)
      [ -z "$STATUS_FILTER" ] && STATUS_FILTER="$1"
      ;;
  esac
  shift
done

PROJECT_KEY="${PROJECT_KEY_OVERRIDE:-${JIRA_PROJECT_KEY:-KAN}}"

os_divider
os_label "  OpenSpec — Jira Tickets  [$PROJECT_KEY]"
os_divider
[ -n "$STATUS_FILTER" ] && os_info "Filter: $STATUS_FILTER"

TICKET_LIST=$(os_jira_list_tickets "$PROJECT_KEY" "$STATUS_FILTER")
echo "$TICKET_LIST"
os_divider

# ── Save snapshot ─────────────────────────────────────────────
CHANGES_DIR="$OS_REPO_ROOT/ai-specs/changes"
mkdir -p "$CHANGES_DIR"
SNAPSHOT_FILE="$CHANGES_DIR/tickets-$(date +%Y%m%d).md"

printf '# Jira Tickets — %s\n' "$(date +%Y-%m-%d)" > "$SNAPSHOT_FILE"
printf 'Project : %s\n' "$PROJECT_KEY"               >> "$SNAPSHOT_FILE"
[ -n "$STATUS_FILTER" ] && printf 'Filter  : %s\n' "$STATUS_FILTER" >> "$SNAPSHOT_FILE"
printf '\n```\n%s\n```\n' "$TICKET_LIST"              >> "$SNAPSHOT_FILE"

os_info "Snapshot: ai-specs/changes/tickets-$(date +%Y%m%d).md"
os_divider
