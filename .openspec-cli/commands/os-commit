#!/bin/sh
# os-commit [TICKET-ID]
# ─────────────────────────────────────────────────────────────
# Detects changed files, generates a conventional commit message,
# stages only relevant files, commits, pushes and opens a PR.
# ALWAYS works on a feature branch — never commits to develop/main.
# ─────────────────────────────────────────────────────────────
set -e

TICKET_ID="${1:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"
. "$CLI_DIR/lib/language.sh"

# Prefer Git for Windows sh/bash over the WSL stub in WindowsApps.
# Without this, husky pre-commit fails with:
#   HCS_E_SERVICE_NOT_AVAILABLE / "Bash/Service/CreateInstance/..."
# and surfaces a misleading "ESLint failed" message.
os_prefer_git_bash() {
  _git_bins=""
  for _candidate in \
    "/c/Program Files/Git/bin" \
    "/c/Program Files/Git/usr/bin" \
    "/c/Program Files (x86)/Git/bin" \
    "/c/Program Files (x86)/Git/usr/bin" \
    "/mnt/c/Program Files/Git/bin" \
    "/mnt/c/Program Files/Git/usr/bin"
  do
    if [ -d "$_candidate" ]; then
      _git_bins="${_git_bins}${_candidate}:"
    fi
  done
  # Native Windows paths when running under a POSIX shell that still sees them
  if [ -n "${PROGRAMFILES:-}" ] && [ -d "$PROGRAMFILES/Git/bin" ]; then
    _git_bins="${_git_bins}${PROGRAMFILES}/Git/bin:${PROGRAMFILES}/Git/usr/bin:"
  fi
  if [ -n "$_git_bins" ]; then
    PATH="${_git_bins}${PATH}"
    export PATH
  fi
  unset _candidate _git_bins
}

os_prefer_git_bash

os_load_config
os_load_env
os_load_language

cd "$OS_REPO_ROOT"

# ── Detect current branch ────────────────────────────────────
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
os_info "Current branch: $CURRENT_BRANCH"

# Try to extract ticket ID from branch name if not provided
if [ -z "$TICKET_ID" ]; then
  TICKET_ID=$(echo "$CURRENT_BRANCH" \
    | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)
fi

# ── Guard: never commit directly to protected branches ────────
PROTECTED="main master develop"
IS_PROTECTED=false
for protected in $PROTECTED; do
  if [ "$CURRENT_BRANCH" = "$protected" ]; then
    IS_PROTECTED=true
    break
  fi
done

if [ "$IS_PROTECTED" = "true" ]; then
  os_warn "You are on a protected branch: $CURRENT_BRANCH"
  os_warn "OpenSpec never commits directly to $CURRENT_BRANCH."
  os_divider

  # Build feature branch name
  if [ -n "$TICKET_ID" ]; then
    FEATURE_BRANCH="feature/${TICKET_ID}-$(date +%Y%m%d)"
  else
    os_info "No ticket ID found. Enter branch name suffix:"
    printf "feature/": read -r SUFFIX
    FEATURE_BRANCH="feature/${SUFFIX}"
  fi

  os_step "Creating branch $FEATURE_BRANCH from $CURRENT_BRANCH..."
  git pull origin "$CURRENT_BRANCH" --quiet
  git checkout -b "$FEATURE_BRANCH"
  os_success "Switched to: $FEATURE_BRANCH"
  CURRENT_BRANCH="$FEATURE_BRANCH"
fi

# ── Check for changes ────────────────────────────────────────
CHANGED_FILES=$(git status --porcelain | grep -v '^??' | awk '{print $2}')
UNTRACKED=$(git status --porcelain | grep '^??' | awk '{print $2}')

if [ -z "$CHANGED_FILES" ] && [ -z "$UNTRACKED" ]; then
  os_warn "No changes detected. Nothing to commit."
  exit 0
fi

os_divider
os_label "  Changed files:"
git status --short
os_divider

# ── Stage relevant changes ───────────────────────────────────
os_step "Staging changes (excluding secrets and build artifacts)..."

git add -u

for f in $UNTRACKED; do
  case "$f" in
    .env|*.env|*.secret|build/*|dist/*|target/*|node_modules/*|__pycache__/*|.angular/*|coverage/*|.cache/*|*.pack|*.pack.old)
      os_warn "Skipping: $f"
      ;;
    openspec/config.yaml)
      # Local agent/stack preference — do not bundle into feature commits
      os_warn "Skipping local OpenSpec config: $f"
      ;;
    *)
      # When committing a ticket, skip plan docs for other tickets
      if [ -n "$TICKET_ID" ]; then
        case "$f" in
          ai-specs/changes/planes/*)
            case "$f" in
              *"${TICKET_ID}"*) ;;
              *)
                os_warn "Skipping unrelated plan: $f"
                continue
                ;;
            esac
            ;;
        esac
      fi
      git add "$f"
      ;;
  esac
done

# Unstage artifacts that may already be tracked or were force-added
STAGED_RAW=$(git diff --cached --name-only || true)
if [ -n "$STAGED_RAW" ]; then
  echo "$STAGED_RAW" | while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      .angular/*|node_modules/*|dist/*|build/*|coverage/*|.cache/*|*.pack|*.pack.old)
        git reset HEAD -- "$f" >/dev/null 2>&1 || true
        os_warn "Unstaged artifact: $f"
        ;;
      openspec/config.yaml)
        git reset HEAD -- "$f" >/dev/null 2>&1 || true
        os_warn "Unstaged local OpenSpec config: $f"
        ;;
      ai-specs/changes/planes/*)
        if [ -n "$TICKET_ID" ]; then
          case "$f" in
            *"${TICKET_ID}"*) ;;
            *)
              git reset HEAD -- "$f" >/dev/null 2>&1 || true
              os_warn "Unstaged unrelated plan: $f"
              ;;
          esac
        fi
        ;;
    esac
  done
fi

STAGED=$(git diff --cached --name-only)
if [ -z "$STAGED" ]; then
  os_warn "Nothing staged after filtering. Aborting."
  exit 1
fi

os_info "Staged files:"
echo "$STAGED" | sed 's/^/  /'

# Harmless on Windows with core.autocrlf=true — do not treat as failure
os_info "Note: CRLF/LF line-ending notices from git are informational only."

# ── Determine scope ──────────────────────────────────────────
SCOPE=$(echo "$STAGED" \
  | grep -oE 'src/[^/]+/[^/]+/[^/]+' \
  | awk -F'/' '{print $4}' \
  | sort | uniq -c | sort -rn \
  | head -1 | awk '{print $2}' \
  | tr '[:upper:]' '[:lower:]' \
  | sed 's/controller//;s/service//;s/handler//')

[ -z "$SCOPE" ] && SCOPE="app"

# ── Build commit message ─────────────────────────────────────
os_step "Building commit message..."

case "$CURRENT_BRANCH" in
  feature/*)  COMMIT_TYPE="feat" ;;
  fix/*)      COMMIT_TYPE="fix" ;;
  test/*)     COMMIT_TYPE="test" ;;
  docs/*)     COMMIT_TYPE="docs" ;;
  chore/*)    COMMIT_TYPE="chore" ;;
  refactor/*) COMMIT_TYPE="refactor" ;;
  *)          COMMIT_TYPE="feat" ;;
esac

FILE_COUNT=$(echo "$STAGED" | wc -l | tr -d ' ')

if [ "$OS_ACTIVE_LANGUAGE" = "es" ]; then
  if [ -n "$TICKET_ID" ]; then
    SUBJECT="${COMMIT_TYPE}(${SCOPE}): implementa $TICKET_ID"
    BODY="- Implementa $TICKET_ID: cambios en $FILE_COUNT archivo(s)
- Stack: $OS_ACTIVE_STACK
- Rama: $CURRENT_BRANCH"
  else
    SUBJECT="${COMMIT_TYPE}(${SCOPE}): aplica cambios de $CURRENT_BRANCH"
    BODY="- Cambios en $FILE_COUNT archivo(s)
- Stack: $OS_ACTIVE_STACK"
  fi
else
  if [ -n "$TICKET_ID" ]; then
    SUBJECT="${COMMIT_TYPE}(${SCOPE}): implement $TICKET_ID"
    BODY="- Implements $TICKET_ID: changes across $FILE_COUNT file(s)
- Stack: $OS_ACTIVE_STACK
- Branch: $CURRENT_BRANCH"
  else
    SUBJECT="${COMMIT_TYPE}(${SCOPE}): apply changes from $CURRENT_BRANCH"
    BODY="- Changes across $FILE_COUNT file(s)
- Stack: $OS_ACTIVE_STACK"
  fi
fi

os_divider
os_label "  Proposed commit message:"
os_divider
echo "  $SUBJECT"
echo ""
echo "$BODY" | sed 's/^/  /'
os_divider

# ── Confirm ──────────────────────────────────────────────────
printf "%b" "${COLOR_WARN}Proceed with this commit? [y/N]: ${RESET}"
read -r confirm
case "$confirm" in
  y|Y|yes|YES) ;;
  *)
    os_warn "Aborted. Your changes are still staged."
    exit 0
    ;;
esac

# ── Commit ───────────────────────────────────────────────────
# Re-apply Git bash preference so husky's `sh` does not hit the WSL stub
os_prefer_git_bash
os_step "Running git commit (husky pre-commit may invoke ESLint)..."
if ! git commit -m "$SUBJECT" -m "$BODY"; then
  os_warn "Commit failed (often husky/ESLint)."
  os_warn "On Windows: ensure Git for Windows is installed and PATH prefers"
  os_warn "  'C:\\Program Files\\Git\\bin' over WindowsApps\\bash.exe (WSL stub)."
  os_warn "If husky reports ESLint failed but you see HCS_E_SERVICE_NOT_AVAILABLE,"
  os_warn "  the shell failed — not ESLint. Re-run from Git Bash or fix PATH."
  os_warn "Also ensure .eslintrc uses tsconfig.app.json (not empty root tsconfig.json)."
  exit 1
fi
os_success "Committed: $SUBJECT"

# ── Push ─────────────────────────────────────────────────────
os_step "Pushing branch $CURRENT_BRANCH..."
git push -u origin "$CURRENT_BRANCH"
os_success "Branch pushed."

# ── Open PR targeting develop ────────────────────────────────
if ! command -v gh > /dev/null 2>&1; then
  os_warn "GitHub CLI (gh) not found — skipping PR creation."
  exit 0
fi

os_step "Creating Pull Request → develop..."

if [ "$OS_ACTIVE_LANGUAGE" = "es" ]; then
  if [ -n "$TICKET_ID" ]; then
    PR_TITLE="[$TICKET_ID] $SUBJECT"
    PR_BODY="## Resumen
Implementa $TICKET_ID en el stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)

## Cambios
$(echo "$STAGED" | sed 's/^/- /')

## Checklist
- [ ] Tests pasan (\`$OS_TEST_CMD\`)
- [ ] Cobertura >= 90% (\`$OS_COVERAGE_CMD\`)
- [ ] Documentación actualizada
- [ ] Endpoints probados manualmente"
  else
    PR_TITLE="$SUBJECT"
    PR_BODY="## Resumen
Stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)
Rama: $CURRENT_BRANCH

## Cambios
$(echo "$STAGED" | sed 's/^/- /')"
  fi
else
  if [ -n "$TICKET_ID" ]; then
    PR_TITLE="[$TICKET_ID] $SUBJECT"
    PR_BODY="## Summary
Implements $TICKET_ID on stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)

## Changes
$(echo "$STAGED" | sed 's/^/- /')

## Checklist
- [ ] Tests pass (\`$OS_TEST_CMD\`)
- [ ] Coverage >= 90% (\`$OS_COVERAGE_CMD\`)
- [ ] Documentation updated
- [ ] Endpoints manually tested"
  else
    PR_TITLE="$SUBJECT"
    PR_BODY="## Summary
Stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)
Branch: $CURRENT_BRANCH

## Changes
$(echo "$STAGED" | sed 's/^/- /')"
  fi
fi

PR_URL=$(gh pr create \
  --title "$PR_TITLE" \
  --body "$PR_BODY" \
  --head "$CURRENT_BRANCH" \
  --base "develop" 2>&1)

os_divider
os_success "Pull Request created → develop"
os_info    "$PR_URL"
os_divider

# Commit/PR live on GitHub — no local ai-specs/changes/commits archive.
os_info "Next: os-review <PR_NUMBER> then os-review-apply <PR_NUMBER>"

