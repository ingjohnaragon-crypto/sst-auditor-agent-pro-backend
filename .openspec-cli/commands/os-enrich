#!/bin/sh
# os-enrich <TICKET-ID>
set -e

TICKET_ID="${1:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"
. "$CLI_DIR/lib/jira.sh"
. "$CLI_DIR/lib/agent.sh"

if [ -z "$TICKET_ID" ]; then
  os_error "Usage: os-enrich <TICKET-ID>"
  exit 1
fi

os_load_config
os_load_env
os_load_agent
os_print_config
os_require_jira_env
os_jira_fetch_ticket "$TICKET_ID"
os_jira_print_ticket

# ── Load context ─────────────────────────────────────────────
AGENT_CONTENT="";    [ -f "$OS_AGENT_PATH" ]     && AGENT_CONTENT=$(cat "$OS_AGENT_PATH")
STANDARDS_CONTENT="";[ -f "$OS_STANDARDS_PATH" ] && STANDARDS_CONTENT=$(cat "$OS_STANDARDS_PATH")
API_SPEC="";          API_FILE="$OS_REPO_ROOT/ai-specs/specs/api-spec.yml"
                      [ -f "$API_FILE" ] && API_SPEC=$(cat "$API_FILE")
DATA_MODEL="";        DM_FILE="$OS_REPO_ROOT/ai-specs/specs/data-model.md"
                      [ -f "$DM_FILE" ] && DATA_MODEL=$(cat "$DM_FILE")
ENRICH_TEMPLATE="";   CMD_FILE="$OS_REPO_ROOT/ai-specs/.commands/enrich-us.md"
                      [ -f "$CMD_FILE" ] && ENRICH_TEMPLATE=$(cat "$CMD_FILE" | sed "s|\$ARGUMENTS|$TICKET_ID|g")

# ── Build prompt ─────────────────────────────────────────────
os_step "Building enrichment prompt..."

PROMPT=$(cat << PROMPT_EOF
You are acting as a product expert with technical knowledge for an openspec project.
Enrich the following Jira ticket with the technical detail a developer needs to be
fully autonomous — no back-and-forth required.

## Active Stack
Stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)

## Jira Ticket: $JIRA_TICKET_ID
Type    : $JIRA_TYPE
Status  : $JIRA_STATUS
Summary : $JIRA_SUMMARY
Assignee: $JIRA_ASSIGNEE

### Original Description
$JIRA_DESCRIPTION

---
## Stack Agent (technical context)
$AGENT_CONTENT

---
## Stack Standards
$STANDARDS_CONTENT

---
## Current API Spec
$API_SPEC

---
## Current Data Model
$DATA_MODEL

---
## Your Task
$ENRICH_TEMPLATE

---
## Output Instructions
Produce ONLY the enhanced description in markdown — no preamble, no explanation.
Include:
- Full description of the functionality
- Fields to create or update
- Endpoint URLs, HTTP methods, request/response shapes
- Files to create or modify (with their architecture layer)
- Acceptance criteria
- Unit test cases to cover
- Non-functional requirements (security, performance, validation)

Write everything in English.
PROMPT_EOF
)

PROMPT_FILE="$OS_REPO_ROOT/.openspec-cli/.last-prompt.md"
OUTPUT_FILE="$OS_REPO_ROOT/.openspec-cli/.enriched-content.md"
printf '%s' "$PROMPT" > "$PROMPT_FILE"

CHANGES_DIR="$OS_REPO_ROOT/ai-specs/changes"
ARCHIVE_FILE="$CHANGES_DIR/${TICKET_ID}_enriched.md"
mkdir -p "$CHANGES_DIR"

os_divider

# ── Deliver and capture output ────────────────────────────────
if [ "${OS_AGENT_DELIVERY:-clipboard}" = "cli" ]; then
  # CLI agent — ejecuta y captura automáticamente
  os_step "Sending prompt to $OS_AGENT_LABEL..."
  ${OS_AGENT_COMMAND} ${OS_AGENT_ARGS} < "$PROMPT_FILE" > "$OUTPUT_FILE" 2>/dev/null
  cp "$OUTPUT_FILE" "$ARCHIVE_FILE"
  os_success "Enriched content saved!"
  os_info "Working : .openspec-cli/.enriched-content.md"
  os_info "Archive : ai-specs/changes/${TICKET_ID}_enriched.md"
  os_divider
  os_info "Preview (first 10 lines):"
  head -10 "$OUTPUT_FILE"
  os_divider
  os_info "Next step: os-enrich-apply $TICKET_ID"
else
  # Clipboard agent — copia prompt y espera que el usuario pegue el output
  printf '%s' "$PROMPT" | clip 2>/dev/null || true
  os_success "Prompt copied to clipboard!"
  os_divider
  os_info "1. Paste in $OS_AGENT_LABEL"
  os_info "2. Copy the AI output"
  os_info "3. Press Enter here when ready..."
  read -r _dummy
  os_step "Paste the enriched content (CTRL+Z + Enter to finish on Windows):"
  OUTPUT=""
  while IFS= read -r line 2>/dev/null; do
    OUTPUT="${OUTPUT}${line}
"
  done
  printf '%s' "$OUTPUT" > "$OUTPUT_FILE"
  cp "$OUTPUT_FILE" "$ARCHIVE_FILE"
  os_success "Saved!"
  os_info "Working : .openspec-cli/.enriched-content.md"
  os_info "Archive : ai-specs/changes/${TICKET_ID}_enriched.md"
  os_divider
  os_info "Preview (first 10 lines):"
  head -10 "$OUTPUT_FILE"
  os_divider
  os_info "Next step: os-enrich-apply $TICKET_ID"
fi

os_divider
