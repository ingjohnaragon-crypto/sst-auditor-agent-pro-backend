#!/bin/sh
# os-review-apply <PR-NUMBER> [file]
# ─────────────────────────────────────────────────────────────
# Publishes Copilot review output as a GitHub PR comment.
# Requires: gh (GitHub CLI)
# ─────────────────────────────────────────────────────────────
set -e

PR_NUMBER="${1:-}"
CONTENT_FILE="${2:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"

if [ -z "$PR_NUMBER" ]; then
  os_error "Usage: os-review-apply <PR-NUMBER> [review-file]"
  os_info  "Example: os-review-apply 1"
  exit 1
fi

if ! command -v gh > /dev/null 2>&1; then
  os_error "GitHub CLI (gh) not found — install from https://cli.github.com"
  exit 1
fi

os_load_config

# ── Resolve review file ──────────────────────────────────────
REVIEW_FILE="$OS_REPO_ROOT/.openspec-cli/.review-output.md"

# Derive ticket ID from PR branch name for archive lookup
PR_BRANCH_NAME=$(gh pr view "$PR_NUMBER" --json headRefName -q .headRefName 2>/dev/null || echo "")
PR_TICKET_ID=$(echo "$PR_BRANCH_NAME" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)
ARCHIVE_FILE=""
[ -n "$PR_TICKET_ID" ] && ARCHIVE_FILE="$OS_REPO_ROOT/ai-specs/changes/${PR_TICKET_ID}_review.md"
[ -z "$ARCHIVE_FILE" ] && ARCHIVE_FILE="$OS_REPO_ROOT/ai-specs/changes/pr-${PR_NUMBER}_review.md"

if [ -n "$CONTENT_FILE" ] && [ -f "$CONTENT_FILE" ]; then
  SOURCE_FILE="$CONTENT_FILE"
elif [ -n "$ARCHIVE_FILE" ] && [ -f "$ARCHIVE_FILE" ]; then
  SOURCE_FILE="$ARCHIVE_FILE"
elif [ -f "$REVIEW_FILE" ]; then
  SOURCE_FILE="$REVIEW_FILE"
else
  os_error "No review file found."
  os_info  "Expected at: ai-specs/changes/${PR_TICKET_ID}_review.md"
  os_info  "Fallback  : .openspec-cli/.review-output.md"
  os_info  "Or run   : os-review $PR_NUMBER"
  exit 1
fi

os_step "Cleaning and reading review from: $SOURCE_FILE"
# Remove vscode-file:// links that break markdown
py -X utf8 -c "
import re, sys
content = open(sys.argv[1], encoding="utf-8").read()
# Replace vscode links with just the filename
content = re.sub(r"\[([^\]]+)\]\(vscode-file://[^)]+\)", r"\", content)
open(sys.argv[1], "w", encoding="utf-8").write(content)
" "$SOURCE_FILE"
CHAR_COUNT=$(wc -c < "$SOURCE_FILE")
os_info "Review size: $CHAR_COUNT characters"

# ── Preview ──────────────────────────────────────────────────
os_divider
os_label "  Preview (first 10 lines):"
os_divider
head -10 "$SOURCE_FILE"
os_divider

# ── Determine verdict for PR action ─────────────────────────
VERDICT=$(grep -iE "^\*\*(APPROVE|REQUEST CHANGES|COMMENT ONLY)\*\*|^APPROVE$|^REQUEST.CHANGES$" \
  "$SOURCE_FILE" | head -1 | tr '[:lower:]' '[:upper:]' || echo "COMMENT")

os_info "Detected verdict: $VERDICT"

# ── Confirm ──────────────────────────────────────────────────
printf "%bPublish review to PR #%s? [y/N]: %b" "$COLOR_WARN" "$PR_NUMBER" "$RESET"
read -r confirm
case "$confirm" in
  y|Y|yes|YES) ;;
  *) os_warn "Aborted."; exit 0 ;;
esac

# ── Add header to review ─────────────────────────────────────
HEADER="<!-- os-review: OpenSpec AI Code Review -->
> **AI Code Review** generated by OpenSpec CLI
> Stack: \`$OS_ACTIVE_STACK\` | Reviewer: Copilot via os-review

---

"
FULL_REVIEW="$HEADER$(cat "$SOURCE_FILE")"

# ── Post comment to PR ───────────────────────────────────────
os_step "Publishing review to PR #$PR_NUMBER..."

TEMP_FILE=$(mktemp)
printf '%s' "$FULL_REVIEW" > "$TEMP_FILE"

gh pr comment "$PR_NUMBER" --body-file "$TEMP_FILE"
rm -f "$TEMP_FILE"

# ── Apply verdict ────────────────────────────────────────────
case "$VERDICT" in
  *APPROVE*)
    os_step "Approving PR..."
    gh pr review "$PR_NUMBER" --approve \
      --body "Approved by OpenSpec AI review. See comment above for details." \
      2>/dev/null && os_success "PR approved!" || os_warn "Could not approve (may need maintainer role)"
    ;;
  *REQUEST*)
    os_step "Requesting changes..."
    gh pr review "$PR_NUMBER" --request-changes \
      --body "Changes requested by OpenSpec AI review. See comment above for details." \
      2>/dev/null && os_success "Changes requested!" || os_warn "Could not request changes"
    ;;
  *)
    os_info "Comment posted — no approval action taken (verdict: COMMENT ONLY)"
    ;;
esac

# ── Archive ──────────────────────────────────────────────────
PR_URL=$(gh pr view "$PR_NUMBER" --json url -q .url 2>/dev/null || echo "")

os_divider
os_success "Review published to PR #$PR_NUMBER!"
[ -n "$PR_URL" ] && os_info "View: $PR_URL"
os_divider

mv "$SOURCE_FILE" "${SOURCE_FILE}.applied" 2>/dev/null || true
os_info "Review archived to: ${SOURCE_FILE}.applied"
