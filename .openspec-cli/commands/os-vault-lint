#!/usr/bin/env bash
# os-vault-lint — Validate Vault Smart Contract Python files against sandbox restrictions
# Usage:
#   os-vault-lint                      # lint contracts/ directory (default)
#   os-vault-lint contracts/foo.py     # lint a specific file
#   os-vault-lint contracts/           # lint a specific directory
#
# Exit codes: 0 = clean, 1 = violations found or target not found

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS_CLI_LIB="${SCRIPT_DIR}/../lib"

source "${OS_CLI_LIB}/colors.sh"
source "${OS_CLI_LIB}/config.sh"
os_load_config

TARGET="${1:-contracts/}"

os_divider
os_label "  OpenSpec — Vault Lint"
os_divider
os_info "Stack  : ${OS_STACK_LABEL:-vault-smart-contracts}"
os_info "Target : ${TARGET}"
os_divider

os_step "Checking Vault Python sandbox restrictions..."

if "${OS_PYTHON}" "${OS_CLI_LIB}/vault_lint.py" "${TARGET}"; then
    os_success "All contracts pass sandbox restriction checks."
else
    os_error "Sandbox violations found. Fix the errors above before running tests."
    exit 1
fi

os_divider
