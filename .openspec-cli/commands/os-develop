#!/bin/sh
# os-develop <TICKET-ID>
set -e

TICKET_ID="${1:-}"
CLI_DIR="$(cd "$(dirname "$0")/.." && pwd)"

. "$CLI_DIR/lib/colors.sh"
. "$CLI_DIR/lib/config.sh"
. "$CLI_DIR/lib/jira.sh"
. "$CLI_DIR/lib/agent.sh"
. "$CLI_DIR/lib/language.sh"

if [ -z "$TICKET_ID" ]; then
  os_error "Usage: os-develop <TICKET-ID>"
  exit 1
fi

os_load_config
os_load_env
os_load_agent
os_load_language
os_print_config
os_print_language
os_require_jira_env
os_jira_fetch_ticket "$TICKET_ID"
os_jira_print_ticket

# ── Create feature branch from develop ───────────────────────
BRANCH="feature/${TICKET_ID}-backend"
os_step "Setting up branch: $BRANCH"
cd "$OS_REPO_ROOT"

if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
  os_info "Branch $BRANCH already exists — switching to it"
  git checkout "$BRANCH"
else
  os_info "Pulling latest develop..."
  git checkout develop 2>/dev/null || git checkout main
  git pull origin "$(git rev-parse --abbrev-ref HEAD)" --quiet
  os_info "Creating branch $BRANCH from develop..."
  git checkout -b "$BRANCH"
fi
os_success "On branch: $BRANCH"

# ── Load context ─────────────────────────────────────────────
AGENT_CONTENT="";    [ -f "$OS_AGENT_PATH" ]     && AGENT_CONTENT=$(cat "$OS_AGENT_PATH")
STANDARDS_CONTENT="";[ -f "$OS_STANDARDS_PATH" ] && STANDARDS_CONTENT=$(cat "$OS_STANDARDS_PATH")
BASE_STANDARDS="";   BASE_FILE="$OS_REPO_ROOT/ai-specs/specs/base-standards.mdc"
                     [ -f "$BASE_FILE" ] && BASE_STANDARDS=$(cat "$BASE_FILE")
DOC_STANDARDS="";    DOC_FILE="$OS_REPO_ROOT/ai-specs/specs/documentation-standards.mdc"
                     [ -f "$DOC_FILE" ] && DOC_STANDARDS=$(cat "$DOC_FILE")
UPDATE_DOCS_TASK="";  UPDATE_DOCS_FILE="$OS_REPO_ROOT/ai-specs/.commands/update-docs.md"
                     [ -f "$UPDATE_DOCS_FILE" ] && UPDATE_DOCS_TASK=$(cat "$UPDATE_DOCS_FILE")

PLAN_FILE="$OS_REPO_ROOT/ai-specs/changes/${TICKET_ID}_backend.md"
PLAN_SECTION=""
if [ -f "$PLAN_FILE" ]; then
  os_success "Found existing plan: $PLAN_FILE"
  PLAN_SECTION="## Implementation Plan
Follow this plan exactly:
$(cat "$PLAN_FILE")"
else
  os_warn "No plan found — run 'os-plan $TICKET_ID' first"
  PLAN_SECTION="## No Plan Found
Run: os-plan $TICKET_ID — then come back to this step."
fi

COMMAND_TEMPLATE="";  CMD_FILE="$OS_REPO_ROOT/ai-specs/.commands/develop-backend.md"
[ -f "$CMD_FILE" ] && COMMAND_TEMPLATE=$(cat "$CMD_FILE" \
  | sed "s|{{build_command}}|$OS_BUILD_CMD|g" \
  | sed "s|{{test_command}}|$OS_TEST_CMD|g" \
  | sed "s|{{run_command}}|$OS_RUN_CMD|g" \
  | sed "s|{{lint_command}}|$OS_LINT_CMD|g" \
  | sed "s|{{coverage_command}}|$OS_COVERAGE_CMD|g" \
  | sed "s|\$ARGUMENTS|$TICKET_ID|g")

# ── Build prompt ─────────────────────────────────────────────
os_step "Building implementation prompt..."

PROMPT=$(cat << PROMPT_EOF
You are acting as the backend-developer agent for an openspec project.
You are on branch: $BRANCH
IMPLEMENT the following Jira ticket following the plan below.

## Active Language
$OS_LANGUAGE_LABEL
$OS_LANGUAGE_DIRECTIVE

## Active Stack
Stack: $OS_ACTIVE_STACK ($OS_STACK_LABEL)
Build   : $OS_BUILD_CMD
Test    : $OS_TEST_CMD
Coverage: $OS_COVERAGE_CMD

## Jira Ticket: $JIRA_TICKET_ID
Summary : $JIRA_SUMMARY

### Description
$JIRA_DESCRIPTION

---
$PLAN_SECTION

---
## Base Standards
$BASE_STANDARDS

---
## Documentation Standards
$DOC_STANDARDS

Documentation update task: $UPDATE_DOCS_TASK

---
## Stack Agent (your role)
$AGENT_CONTENT

---
## Stack Standards
$STANDARDS_CONTENT

---
## Implementation Instructions
$COMMAND_TEMPLATE
PROMPT_EOF
)

PROMPT_FILE="$OS_REPO_ROOT/.openspec-cli/.last-prompt.md"
printf '%s' "$PROMPT" > "$PROMPT_FILE"

os_divider

# ── Deliver prompt ────────────────────────────────────────────
# os-develop is different: the AI writes code directly into files.
os_deliver_prompt_autonomous "$PROMPT_FILE"

if [ "${OS_AGENT_DELIVERY:-clipboard}" = "cli" ]; then
  os_divider
  os_success "Implementation complete — review the changes:"
  git status --short
fi

os_divider
os_info "Next step: $OS_TEST_CMD && os-commit $TICKET_ID"
os_divider
